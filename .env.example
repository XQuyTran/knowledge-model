# ─────────────────────────────────────────────
# Diagnostic Pipeline — Environment Config
# ─────────────────────────────────────────────

# --- Neo4j (Graph Database) ---
USE_NEO4J=true
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# --- App ---
APP_PORT=8000
CORS_ALLOW_ORIGINS=*

# --- Resource Limits ---
NEO4J_HEAP_INITIAL=512M
NEO4J_HEAP_MAX=1G
NEO4J_PAGECACHE=512M
NEO4J_MEM_LIMIT=2g
NEO4J_CPU_LIMIT=2.0
APP_MEM_LIMIT=1g
APP_CPU_LIMIT=1.5
